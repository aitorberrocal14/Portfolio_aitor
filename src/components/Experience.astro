---
import SectionHeader from '~/components/SectionHeader.astro';
import { experience } from '~/data/site';
---

<section id="experiencia" class="section">
  <div class="container">
    <SectionHeader
      number="04"
      label="Trayectoria"
      title="De la universidad a producir productos con IA."
    />

    <ol class="mt-20 relative border-l-2 border-slate-200 space-y-14 pl-8 max-w-3xl">
      {experience.map((item, i) => (
        <li class="relative" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
          <span class="absolute -left-[41px] top-2 grid h-5 w-5 place-items-center rounded-full bg-white border-2 border-navy shadow">
            <span class="h-2 w-2 rounded-full bg-navy"></span>
          </span>
          <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
            <p class="section-number">{item.period}</p>
            <span class="h-px flex-1 bg-slate-200"></span>
          </div>
          <h3 class="mt-3 font-display text-2xl sm:text-3xl text-navy tracking-tight">{item.role}</h3>
          <p class="mt-1 text-slate-500">{item.org}</p>
          <p class="mt-4 text-lg text-slate-700 leading-relaxed max-w-2xl">{item.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
