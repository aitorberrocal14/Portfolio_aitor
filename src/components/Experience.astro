---
import { experience } from '~/data/site';
---

<section id="experiencia" class="section">
  <div class="container grid lg:grid-cols-[1fr,2fr] gap-12">
    <div>
      <p class="eyebrow">Experiencia</p>
      <h2 class="heading mt-4">Trayectoria</h2>
      <p class="mt-4 text-slate-400 text-sm">
        Formación académica y experiencia profesional que sostienen mi forma de trabajar.
      </p>
    </div>

    <ol class="relative border-l border-white/10 space-y-10 pl-6">
      {experience.map((item) => (
        <li class="relative">
          <span class="absolute -left-[33px] top-1 grid h-4 w-4 place-items-center rounded-full border border-white/20 bg-ink">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          </span>
          <p class="text-xs uppercase tracking-widest text-slate-500">{item.period}</p>
          <h3 class="mt-1 font-display text-xl text-white">{item.role}</h3>
          <p class="text-slate-400 text-sm">{item.org}</p>
          <p class="mt-3 text-slate-300 leading-relaxed">{item.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
