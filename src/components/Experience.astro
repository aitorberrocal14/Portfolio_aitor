---
import SectionHeader from '~/components/SectionHeader.astro';
import { experience } from '~/data/site';
---

<section id="experiencia" class="section section-divide">
  <div class="container">
    <SectionHeader
      number="04"
      label="Trayectoria"
      title="Dónde he estado trabajando."
    />

    <ol class="mt-14 relative border-l-2 border-slate-200 space-y-10 pl-7 max-w-3xl">
      {experience.map((item, i) => (
        <li class="relative" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
          <span class="absolute -left-[37px] top-1.5 grid h-4 w-4 place-items-center rounded-full bg-white border-2 border-navy">
            <span class="h-1.5 w-1.5 rounded-full bg-navy"></span>
          </span>
          <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
            <p class="section-number">{item.period}</p>
            <span class="h-px flex-1 bg-slate-200"></span>
          </div>
          <h3 class="mt-2 font-display text-xl sm:text-2xl text-navy tracking-tight">{item.role}</h3>
          <p class="mt-0.5 text-sm text-slate-500">{item.org}</p>
          <p class="mt-3 text-base text-slate-700 leading-relaxed max-w-2xl">{item.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
