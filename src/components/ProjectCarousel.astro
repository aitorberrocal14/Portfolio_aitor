---
import type { Project } from '~/data/site';
import BrowserMock from '~/components/BrowserMock.astro';

export interface Props {
  title: string;
  kicker: string;
  items: Project[];
  carouselId: string;
}

const { title, kicker, items, carouselId }: Props = Astro.props;
---

<div class="mt-14" data-reveal>
  <div class="container flex items-end justify-between gap-6 mb-6">
    <div>
      <p class="section-number">{kicker}</p>
      <h3 class="font-display text-2xl sm:text-3xl text-navy tracking-tight mt-2">{title}</h3>
    </div>

    <div class="flex items-center gap-3">
      <span class="hidden sm:inline-flex items-center gap-2 text-xs text-slate-500 mr-2">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 12h10M11 6l-5 6 5 6M13 6l5 6-5 6" />
        </svg>
        Desliza
      </span>
      <button
        type="button"
        data-scroll={carouselId}
        data-dir="-1"
        class="grid h-10 w-10 place-items-center rounded-full border border-slate-300 text-navy transition hover:border-navy hover:bg-navy hover:text-white"
        aria-label="Anterior"
      >
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 4L7 10l6 6" />
        </svg>
      </button>
      <button
        type="button"
        data-scroll={carouselId}
        data-dir="1"
        class="grid h-10 w-10 place-items-center rounded-full border border-slate-300 text-navy transition hover:border-navy hover:bg-navy hover:text-white"
        aria-label="Siguiente"
      >
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 4l6 6-6 6" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id={carouselId}
    class="h-scroll overflow-x-auto flex gap-5 sm:gap-6 scroll-smooth pb-4 pl-[max(1.25rem,calc((100vw-1120px)/2+1.25rem))] pr-6 cursor-grab active:cursor-grabbing"
  >
    {items.map((p, i) => (
      <article
        class="snap-start group relative flex-none w-[88%] sm:w-[560px] lg:w-[620px] rounded-3xl overflow-hidden border border-slate-200 bg-white transition duration-500 hover:shadow-2xl hover:shadow-navy/10 hover:-translate-y-1"
      >
        <div class="relative h-56 sm:h-64 overflow-hidden">
          <BrowserMock
            bg={p.cover.bg}
            fg={p.cover.fg}
            tagline={p.cover.tagline}
            monogram={p.cover.monogram}
            urlLabel={p.cover.urlLabel}
          />

          <div class="absolute top-4 left-4 flex gap-2">
            <span class="rounded-full bg-black/20 backdrop-blur px-2.5 py-0.5 text-[10px] font-medium text-white">
              {String(i + 1).padStart(2, '0')} / {String(items.length).padStart(2, '0')}
            </span>
            <span class="rounded-full bg-black/20 backdrop-blur px-2.5 py-0.5 text-[10px] font-medium text-white">
              {p.year}
            </span>
          </div>

          {p.url && (
            <a
              href={p.url}
              target="_blank"
              rel="noopener"
              class="absolute inset-0 flex items-end justify-end p-4 opacity-0 group-hover:opacity-100 transition duration-300"
              aria-label={`Abrir ${p.title}`}
            >
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white px-3 py-1.5 text-xs font-semibold text-navy shadow-lg">
                Abrir sitio
                <svg class="h-3 w-3" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 13L13 7M7 7h6v6" />
                </svg>
              </span>
            </a>
          )}
        </div>

        <div class="p-6 sm:p-7">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-400">{p.subtitle}</p>
              <h4 class="mt-1 font-display text-2xl sm:text-3xl text-navy leading-tight">{p.title}</h4>
            </div>
          </div>

          <p class="mt-4 text-slate-600 leading-relaxed text-sm sm:text-base">{p.description}</p>

          {p.highlights.length > 0 && (
            <ul class="mt-4 space-y-1.5 text-sm text-slate-600">
              {p.highlights.map((h) => (
                <li class="flex gap-2">
                  <span class="text-navy mt-1 leading-none">—</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}

          <div class="mt-5 flex flex-wrap gap-2">
            {p.tags.map((t) => <span class="pill">{t}</span>)}
          </div>

          {p.url && (
            <a
              href={p.url}
              target="_blank"
              rel="noopener"
              class="mt-6 inline-flex items-center justify-center w-full gap-2 rounded-full bg-navy px-5 py-3 text-sm font-semibold text-white transition hover:bg-navy-700"
            >
              Visitar {p.cover.urlLabel || 'el sitio'}
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 13L13 7M7 7h6v6" />
              </svg>
            </a>
          )}
        </div>
      </article>
    ))}

    <div class="flex-none w-6" aria-hidden="true"></div>
  </div>

  <div class="container mt-4 flex items-center gap-2" aria-hidden="true">
    {items.map((_, i) => (
      <span data-dot={carouselId} data-index={i} class={`h-1 rounded-full transition-all duration-300 ${i === 0 ? 'w-8 bg-navy' : 'w-4 bg-slate-300'}`}></span>
    ))}
  </div>
</div>
