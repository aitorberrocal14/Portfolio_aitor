---
import LanguageSwitcher from '~/components/LanguageSwitcher.astro';
import { getDict, getLang, notesUrl } from '~/i18n';

const t = getDict(Astro.url).nav;
const lang = getLang(Astro.url);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const root = lang === 'es' ? base : `${base}${lang}/`;
const notesHref = notesUrl(lang, base);

const nav = [
  { href: `${root}#sobre-mi`, label: t.about, number: '01', target: 'sobre-mi' },
  { href: `${root}#servicios`, label: t.services, number: '02', target: 'servicios' },
  { href: `${root}#proyectos`, label: t.projects, number: '03', target: 'proyectos' },
  { href: `${root}#experiencia`, label: t.experience, number: '04', target: 'experiencia' },
  { href: `${root}#herramientas`, label: t.tools, number: '05', target: 'herramientas' },
  { href: `${root}#formacion`, label: t.education, number: '06', target: 'formacion' },
  { href: notesHref, label: t.notes, number: '07', target: null as string | null },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-slate-200/80 bg-white/80 backdrop-blur-md">
  <div class="container flex items-center justify-between gap-4 py-4">
    <a href={`${root}#top`} class="group flex items-center gap-2.5 flex-none">
      <span class="grid h-9 w-9 place-items-center rounded-full bg-navy text-sm font-bold text-white transition group-hover:scale-105">
        AB
      </span>
      <span class="font-display text-lg text-navy group-hover:opacity-80 tracking-tight hidden sm:inline lg:hidden">
        Aitor Berrocal
      </span>
      <span class="font-display text-lg text-navy group-hover:opacity-80 tracking-tight hidden lg:inline">
        Aitor Berrocal Lorda
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-6 text-sm flex-1 justify-center">
      {nav.map((item) => (
        <a
          href={item.href}
          {...(item.target ? { 'data-nav-link': item.target } : {})}
          class="group relative text-slate-600 hover:text-navy transition-colors py-1.5 data-[active=true]:text-navy whitespace-nowrap"
        >
          <span>{item.label}</span>
          <span class="absolute -bottom-0.5 left-0 right-0 h-0.5 rounded-full bg-navy scale-x-0 origin-left transition-transform duration-300 group-data-[active=true]:scale-x-100"></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 flex-none">
      <LanguageSwitcher />
      <a href={`${root}#contacto`} class="btn hidden sm:inline-flex">
        {t.cta}
        <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 10h10M11 4l6 6-6 6" />
        </svg>
      </a>
      <button
        type="button"
        id="mobile-menu-toggle"
        class="lg:hidden grid h-10 w-10 place-items-center rounded-full border border-slate-300 text-navy"
        aria-label={t.openMenu}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg id="icon-close" class="h-5 w-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 6l12 12M6 18L18 6" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden border-t border-slate-200 bg-white/95 backdrop-blur-md overflow-hidden transition-[max-height,opacity] duration-300 ease-out max-h-0 opacity-0"
    aria-hidden="true"
  >
    <nav class="container py-4 grid gap-1 text-base">
      {nav.map((item) => (
        <a
          href={item.href}
          {...(item.target ? { 'data-nav-link': item.target } : {})}
          data-mobile-link
          class="flex items-center justify-between rounded-xl px-4 py-3 text-slate-700 hover:bg-slate-50 hover:text-navy transition-colors data-[active=true]:bg-navy/5 data-[active=true]:text-navy"
        >
          <span class="flex items-center gap-3">
            <span class="font-mono text-[10px] text-slate-400">{item.number}</span>
            {item.label}
          </span>
          <svg class="h-3.5 w-3.5 text-slate-400" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 10h10M11 4l6 6-6 6" />
          </svg>
        </a>
      ))}
      <a
        href={`${root}#contacto`}
        data-mobile-link
        class="mt-2 inline-flex items-center justify-center gap-2 rounded-xl bg-navy px-4 py-3 text-sm font-semibold text-white"
      >
        {t.cta}
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 10h10M11 4l6 6-6 6" />
        </svg>
      </a>
    </nav>
  </div>
</header>
<div class="h-[68px]" aria-hidden="true"></div>

<script is:inline>
  (function () {
    const btn = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');
    if (!btn || !menu) return;

    let open = false;
    const setOpen = (v) => {
      open = v;
      btn.setAttribute('aria-expanded', v ? 'true' : 'false');
      menu.setAttribute('aria-hidden', v ? 'false' : 'true');
      if (v) {
        menu.style.maxHeight = menu.scrollHeight + 'px';
        menu.style.opacity = '1';
      } else {
        menu.style.maxHeight = '0px';
        menu.style.opacity = '0';
      }
      iconOpen.classList.toggle('hidden', v);
      iconClose.classList.toggle('hidden', !v);
    };

    btn.addEventListener('click', () => setOpen(!open));
    menu.querySelectorAll('[data-mobile-link]').forEach((l) => {
      l.addEventListener('click', () => setOpen(false));
    });
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024 && open) setOpen(false);
    });
  })();
</script>
