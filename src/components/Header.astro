---
import { site } from '~/data/site';

const nav = [
  { href: '#sobre-mi', label: 'Sobre mí' },
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#experiencia', label: 'Experiencia' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/80 backdrop-blur">
  <div class="container flex items-center justify-between py-4">
    <a href="#top" class="group flex items-center gap-2">
      <span class="grid h-8 w-8 place-items-center rounded-full bg-navy text-sm font-bold text-white">
        AB
      </span>
      <span class="font-display text-lg text-navy group-hover:opacity-80">{site.name}</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm">
      {nav.map((item) => (
        <a href={item.href} class="link">{item.label}</a>
      ))}
    </nav>

    <a href="#contacto" class="btn hidden sm:inline-flex">Contacta</a>
  </div>
</header>
