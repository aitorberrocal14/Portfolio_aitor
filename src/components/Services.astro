---
import SectionHeader from '~/components/SectionHeader.astro';
import { services } from '~/data/site';
---

<section id="servicios" class="section section-divide bg-white">
  <div class="container">
    <SectionHeader
      number="02"
      label="Cómo trabajo"
      title="Tres formas de colaborar."
      description="Dependiendo del punto de partida, entro por una u otra puerta: investigación, producto o ambas."
    />

    <div class="mt-14 grid md:grid-cols-3 gap-5">
      {services.map((s, i) => (
        <article class="card group relative flex flex-col" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
          <div class="flex items-start justify-between">
            <span class="font-mono text-sm text-slate-400">{s.number}</span>
            <span class="grid h-8 w-8 place-items-center rounded-full border border-slate-200 text-slate-400 transition group-hover:border-navy group-hover:text-navy">
              <svg class="h-3.5 w-3.5 transition-transform group-hover:rotate-45" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 15L15 5M9 5h6v6" />
              </svg>
            </span>
          </div>
          <h3 class="mt-5 font-display text-xl text-navy">{s.title}</h3>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed">{s.description}</p>

          <ul class="mt-5 space-y-1.5 border-t border-slate-100 pt-4 text-sm text-slate-600 flex-1">
            {s.deliverables.map((d) => (
              <li class="flex items-start gap-2">
                <span class="mt-[0.4em] h-1 w-1 rounded-full bg-navy/50 flex-none"></span>
                <span>{d}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
