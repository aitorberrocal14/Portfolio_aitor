---
export interface Props {
  bg: string;
  fg: string;
  tagline: string;
  monogram: string;
  urlLabel?: string;
}

const { bg, fg, tagline, monogram, urlLabel = '' }: Props = Astro.props;
---

<div class="relative h-full w-full flex flex-col" style={`background-color: ${bg}; color: ${fg};`}>
  <div class="flex items-center gap-2 px-4 py-2.5 border-b" style={`border-color: ${fg}22; background-color: ${fg}0d;`}>
    <span class="h-2.5 w-2.5 rounded-full" style="background-color: rgba(255,255,255,0.35)"></span>
    <span class="h-2.5 w-2.5 rounded-full" style="background-color: rgba(255,255,255,0.25)"></span>
    <span class="h-2.5 w-2.5 rounded-full" style="background-color: rgba(255,255,255,0.15)"></span>
    <span
      class="ml-3 px-3 py-1 rounded-md text-[11px] font-mono truncate max-w-[70%]"
      style={`background-color: ${fg}18; color: ${fg}; letter-spacing: 0.02em;`}
    >
      {urlLabel}
    </span>
  </div>

  <div class="relative flex-1 overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none opacity-40"
      style={`background-image: radial-gradient(${fg}33 1px, transparent 1px); background-size: 18px 18px;`}
    ></div>
    <div class="absolute -bottom-10 -right-10 h-40 w-40 rounded-full opacity-20" style={`background-color: ${fg};`}></div>

    <div class="relative h-full flex flex-col justify-between p-5 sm:p-7">
      <div class="flex items-start justify-between">
        <span
          class="text-[10px] uppercase tracking-[0.25em] font-semibold"
          style={`color: ${fg}99;`}
        >
          Live preview
        </span>
        <span
          class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[10px] font-mono"
          style={`background-color: ${fg}18; color: ${fg};`}
        >
          <span class="h-1.5 w-1.5 rounded-full" style={`background-color: ${fg};`}></span>
          Online
        </span>
      </div>

      <div>
        <p class="font-display text-[clamp(3rem,10vw,5rem)] leading-none tracking-tight" style={`color: ${fg};`}>
          {monogram}
        </p>
        <p class="mt-3 text-base sm:text-lg font-medium max-w-xs" style={`color: ${fg}cc;`}>
          {tagline}
        </p>
      </div>
    </div>
  </div>
</div>
