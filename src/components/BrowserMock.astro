---
export interface Props {
  bg: string;
  fg: string;
  tagline: string;
  monogram: string;
  urlLabel?: string;
}

const { bg, fg, tagline, monogram, urlLabel = '' }: Props = Astro.props;
---

<div class="relative h-full w-full flex flex-col" style={`background-color: ${bg}; color: ${fg};`}>
  <div class="flex items-center gap-1.5 px-3 py-2 border-b" style={`border-color: ${fg}22; background-color: ${fg}0d;`}>
    <span class="h-2 w-2 rounded-full" style="background-color: rgba(255,255,255,0.35)"></span>
    <span class="h-2 w-2 rounded-full" style="background-color: rgba(255,255,255,0.25)"></span>
    <span class="h-2 w-2 rounded-full" style="background-color: rgba(255,255,255,0.15)"></span>
    <span
      class="ml-2 px-2 py-0.5 rounded text-[9px] font-mono truncate max-w-[75%]"
      style={`background-color: ${fg}18; color: ${fg}; letter-spacing: 0.02em;`}
    >
      {urlLabel}
    </span>
  </div>

  <div class="relative flex-1 overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none opacity-40"
      style={`background-image: radial-gradient(${fg}33 1px, transparent 1px); background-size: 14px 14px;`}
    ></div>
    <div class="absolute -bottom-8 -right-8 h-28 w-28 rounded-full opacity-20" style={`background-color: ${fg};`}></div>

    <div class="relative h-full flex flex-col justify-end p-3.5 sm:p-4">
      <p class="font-display text-[clamp(1.75rem,6vw,2.75rem)] leading-none tracking-tight" style={`color: ${fg};`}>
        {monogram}
      </p>
      <p class="mt-1.5 text-xs sm:text-sm font-medium leading-tight" style={`color: ${fg}cc;`}>
        {tagline}
      </p>
    </div>
  </div>
</div>
