---
import SectionHeader from '~/components/SectionHeader.astro';
import ProjectGrid from '~/components/ProjectGrid.astro';
import { getDict } from '~/i18n';
import { projectMeta } from '~/data/site';

const t = getDict(Astro.url).projects;
const merge = (item: typeof t.items[number]) => ({ ...item, ...projectMeta[item.id] });

const software = (['toca', 'mozkor', 'bercay'] as const)
  .map((id) => t.items.find((i) => i.id === id)!)
  .map(merge);
const research = (['tfm', 'turismo-bilbao'] as const)
  .map((id) => t.items.find((i) => i.id === id)!)
  .map(merge);
---

<section id="proyectos" class="section section-divide">
  <div class="container">
    <SectionHeader
      number={t.number}
      label={t.kicker}
      title={t.title}
      description={t.description}
    />

    <ProjectGrid
      kicker={t.softwareKicker}
      title={t.softwareTitle}
      items={software}
      countLabel={t.countLabel(software.length)}
      openLabel={t.openLabel}
      visitLabel={t.visitLabel}
      noUrlLabel={t.noUrlLabel}
    />

    <ProjectGrid
      kicker={t.researchKicker}
      title={t.researchTitle}
      items={research}
      countLabel={t.countLabel(research.length)}
      openLabel={t.openLabel}
      visitLabel={t.visitLabel}
      noUrlLabel={t.noUrlLabel}
    />
  </div>
</section>
