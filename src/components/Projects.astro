---
import SectionHeader from '~/components/SectionHeader.astro';
import ProjectGrid from '~/components/ProjectGrid.astro';
import { projects } from '~/data/site';

const software = projects.filter((p) => p.category === 'software');
const research = projects.filter((p) => p.category === 'investigacion');
---

<section id="proyectos" class="section section-divide">
  <div class="container">
    <SectionHeader
      number="03"
      label="Trabajo seleccionado"
      title="Proyectos que cruzan investigación y tecnología."
      description="Lo que construyo bajo Bercay Studio y lo que investigo en entornos académicos y aplicados."
    />

    <ProjectGrid
      kicker="— Rama 01"
      title="Software & IA"
      items={software}
    />

    <ProjectGrid
      kicker="— Rama 02"
      title="Investigación social"
      items={research}
    />
  </div>
</section>
