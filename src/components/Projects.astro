---
import SectionHeader from '~/components/SectionHeader.astro';
import ProjectCarousel from '~/components/ProjectCarousel.astro';
import { projects } from '~/data/site';

const software = projects.filter((p) => p.category === 'software');
const research = projects.filter((p) => p.category === 'investigacion');
---

<section id="proyectos" class="section">
  <div class="container">
    <SectionHeader
      number="02"
      label="Trabajo seleccionado"
      title="Proyectos que cruzan investigación y tecnología."
      description="Desliza para recorrer cada categoría. Puedes arrastrar, usar las flechas o scrollear con el trackpad."
    />
  </div>

  <ProjectCarousel
    carouselId="carousel-software"
    kicker="— Rama 01"
    title="Software & IA"
    items={software}
  />

  <ProjectCarousel
    carouselId="carousel-research"
    kicker="— Rama 02"
    title="Investigación social"
    items={research}
  />
</section>

<script is:inline>
  document.querySelectorAll('[data-scroll]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-scroll');
      const dir = Number(btn.getAttribute('data-dir') || '1');
      const el = document.getElementById(id);
      if (!el) return;
      const card = el.querySelector('article');
      const step = card ? card.getBoundingClientRect().width + 24 : 400;
      el.scrollBy({ left: step * dir, behavior: 'smooth' });
    });
  });
</script>
