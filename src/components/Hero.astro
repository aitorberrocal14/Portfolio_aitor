---
import { site, stats } from '~/data/site';
---

<section id="top" class="relative overflow-hidden pt-24 sm:pt-32 pb-20 sm:pb-24">
  <div class="absolute inset-0 bg-dots opacity-20 pointer-events-none"></div>
  <div class="absolute top-1/3 -right-20 h-72 w-72 rounded-full bg-navy/8 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 -left-20 h-64 w-64 rounded-full bg-navy/5 blur-3xl pointer-events-none"></div>

  <div class="container relative">
    <div class="flex items-center gap-3 mb-8" data-reveal>
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span class="text-sm font-medium text-slate-600">Disponible para nuevos proyectos · {site.location}</span>
    </div>

    <h1 class="heading-mega max-w-4xl" data-reveal style="--reveal-delay: 80ms">
      Investigo lo social<br />
      y <span class="italic text-navy-700">construyo</span> con IA<span class="text-navy-500">.</span>
    </h1>

    <div class="mt-8 grid lg:grid-cols-[1.4fr,1fr] gap-8 items-end">
      <p class="max-w-2xl text-base sm:text-lg text-slate-600 leading-relaxed" data-reveal style="--reveal-delay: 180ms">
        Soy <span class="text-navy font-medium">{site.name}</span>. Sociólogo e investigador social que desarrolla software y apps apoyándose en modelos de lenguaje.
        Combino <em class="text-navy-700 not-italic font-medium">rigor metodológico</em> con <em class="text-navy-700 not-italic font-medium">velocidad de ejecución</em>.
      </p>

      <div class="flex flex-wrap gap-3 lg:justify-end" data-reveal style="--reveal-delay: 260ms">
        <a href="#proyectos" class="btn-primary group">
          Ver proyectos
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 10h10M11 4l6 6-6 6" />
          </svg>
        </a>
        <a href="#contacto" class="btn">Hablemos</a>
      </div>
    </div>

    <div class="mt-16 grid grid-cols-3 gap-6 max-w-2xl" data-reveal style="--reveal-delay: 340ms">
      {stats.map((s) => (
        <div class="border-t border-slate-300 pt-3">
          <p class="font-display text-2xl sm:text-3xl text-navy">{s.value}</p>
          <p class="mt-1 text-xs text-slate-500 leading-snug">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
