---
import { site } from '~/data/site';
import SocialLinks from '~/components/SocialLinks.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 py-10 mt-10">
  <div class="container flex flex-col sm:flex-row items-center justify-between gap-5 text-sm text-slate-400">
    <p>© {year} {site.name}. Hecho con Astro + Tailwind.</p>
    <SocialLinks />
  </div>
</footer>
