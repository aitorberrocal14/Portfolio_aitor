---
import { site } from '~/data/site';
import SocialLinks from '~/components/SocialLinks.astro';
import { getDict } from '~/i18n';

const t = getDict(Astro.url).footer;
const year = new Date().getFullYear();
---

<footer class="section-divide bg-white">
  <div class="container py-12">
    <div class="grid lg:grid-cols-[1.5fr,1fr] gap-8 items-end">
      <div>
        <p class="section-number">{site.shortName}</p>
        <p class="mt-2 font-display text-2xl sm:text-3xl text-navy tracking-tight leading-tight max-w-xl">
          {t.tagline}
        </p>
      </div>
      <div class="flex lg:justify-end">
        <SocialLinks />
      </div>
    </div>
  </div>

  <div class="border-t border-slate-200">
    <div class="container py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-slate-500">
      <p>© {year} {site.name}. {t.rights}</p>
      <p>{t.builtWith}</p>
    </div>
  </div>
</footer>
