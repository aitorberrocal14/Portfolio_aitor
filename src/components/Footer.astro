---
import { site } from '~/data/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 py-10 mt-10">
  <div class="container flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-400">
    <p>© {year} {site.name}. Hecho con Astro + Tailwind.</p>
    <div class="flex items-center gap-5">
      {site.socials.github && <a class="link" href={site.socials.github} target="_blank" rel="noopener">GitHub</a>}
      {site.socials.linkedin && <a class="link" href={site.socials.linkedin} target="_blank" rel="noopener">LinkedIn</a>}
      {site.email && <a class="link" href={`mailto:${site.email}`}>Email</a>}
    </div>
  </div>
</footer>
