---
import BrowserMock from '~/components/BrowserMock.astro';

export interface ProjectItem {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  tags: readonly string[] | string[];
  highlights: readonly string[] | string[];
  cover: { tagline: string; urlLabel: string };
  url?: string;
  year: string;
  bg: string;
  fg: string;
  monogram: string;
}

export interface Props {
  title: string;
  kicker: string;
  items: ProjectItem[];
  countLabel: string;
  openLabel: string;
  visitLabel: string;
  noUrlLabel: string;
}

const { title, kicker, items, countLabel, openLabel, visitLabel, noUrlLabel }: Props = Astro.props;

// Unique id per carousel for scroll/dot wiring.
const cid = `pc-${kicker.replace(/[^\w]/g, '')}-${Math.random().toString(36).slice(2, 7)}`;
---

<div class="mt-12" data-reveal>
  <div class="flex items-end justify-between gap-4 mb-6">
    <div>
      <p class="section-number">{kicker}</p>
      <h3 class="font-display text-xl sm:text-2xl text-navy tracking-tight mt-1.5">{title}</h3>
    </div>
    <div class="flex items-center gap-3">
      <span class="hidden sm:inline-flex items-center gap-2 text-xs text-slate-500 mr-1">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 12h10M11 6l-5 6 5 6M13 6l5 6-5 6" />
        </svg>
        {countLabel}
      </span>
      <button
        type="button"
        data-scroll={cid}
        data-dir="-1"
        class="grid h-10 w-10 place-items-center rounded-full border border-slate-300 text-navy transition hover:border-navy hover:bg-navy hover:text-white"
        aria-label="Anterior"
      >
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 4L7 10l6 6" />
        </svg>
      </button>
      <button
        type="button"
        data-scroll={cid}
        data-dir="1"
        class="grid h-10 w-10 place-items-center rounded-full border border-slate-300 text-navy transition hover:border-navy hover:bg-navy hover:text-white"
        aria-label="Siguiente"
      >
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 4l6 6-6 6" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id={cid}
    class="h-scroll overflow-x-auto flex gap-4 sm:gap-5 scroll-smooth pb-4 -mx-[max(1rem,calc((100vw-1120px)/2+1rem))] px-[max(1rem,calc((100vw-1120px)/2+1rem))] cursor-grab active:cursor-grabbing"
  >
    {items.map((p, i) => (
      <article
        class="snap-start group relative flex-none w-[85%] sm:w-[360px] lg:w-[400px] flex flex-col rounded-2xl overflow-hidden border border-slate-200 bg-white transition duration-300 hover:shadow-xl hover:shadow-navy/10 hover:-translate-y-0.5"
      >
        <div class="relative h-36 overflow-hidden">
          <BrowserMock
            bg={p.bg}
            fg={p.fg}
            tagline={p.cover.tagline}
            monogram={p.monogram}
            urlLabel={p.cover.urlLabel}
          />
          <div class="absolute top-2.5 right-2.5 rounded-full bg-black/20 backdrop-blur px-2 py-0.5 text-[9px] font-medium text-white tracking-wide">
            {p.year}
          </div>
          {p.url && (
            <a
              href={p.url}
              target="_blank"
              rel="noopener"
              class="absolute inset-0 flex items-end justify-end p-2.5 opacity-0 group-hover:opacity-100 transition duration-300"
              aria-label={`${openLabel} ${p.title}`}
            >
              <span class="inline-flex items-center gap-1 rounded-full bg-white px-2.5 py-1 text-[10px] font-semibold text-navy shadow">
                {openLabel}
                <svg class="h-2.5 w-2.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 13L13 7M7 7h6v6" />
                </svg>
              </span>
            </a>
          )}
        </div>

        <div class="p-4 sm:p-5 flex-1 flex flex-col">
          <p class="text-[10px] uppercase tracking-[0.18em] text-slate-400">{p.subtitle}</p>
          <h4 class="mt-1 font-display text-lg text-navy leading-tight">{p.title}</h4>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed line-clamp-3">{p.description}</p>

          <div class="mt-3 flex flex-wrap gap-1.5">
            {p.tags.slice(0, 4).map((tag) => (
              <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-[10px] text-slate-600">{tag}</span>
            ))}
          </div>

          <div class="mt-auto pt-4 flex items-center justify-between gap-2 border-t border-slate-100 mt-4">
            {p.url ? (
              <a
                href={p.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 text-xs font-semibold text-navy hover:gap-2 transition-all"
              >
                {visitLabel}
                <svg class="h-3 w-3" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 13L13 7M7 7h6v6" />
                </svg>
              </a>
            ) : (
              <span class="text-xs text-slate-400">{p.cover.urlLabel || noUrlLabel}</span>
            )}
            <span class="text-[10px] font-mono text-slate-300">{String(i + 1).padStart(2, '0')}</span>
          </div>
        </div>
      </article>
    ))}

    <div class="flex-none w-2" aria-hidden="true"></div>
  </div>

  <div class="mt-3 flex items-center gap-1.5" aria-hidden="true">
    {items.map((_, i) => (
      <span data-dot={cid} data-index={i} class={`h-1 rounded-full transition-all duration-300 ${i === 0 ? 'w-6 bg-navy' : 'w-3 bg-slate-300'}`}></span>
    ))}
  </div>
</div>

<script is:inline data-cid={cid}>
  (function () {
    const cid = document.currentScript.getAttribute('data-cid');
    const el = document.getElementById(cid);
    if (!el) return;
    const dots = document.querySelectorAll(`[data-dot="${cid}"]`);

    // Arrow buttons
    document.querySelectorAll(`[data-scroll="${cid}"]`).forEach((btn) => {
      btn.addEventListener('click', () => {
        const dir = Number(btn.getAttribute('data-dir') || '1');
        const card = el.querySelector('article');
        const step = card ? card.getBoundingClientRect().width + 20 : 380;
        el.scrollBy({ left: step * dir, behavior: 'smooth' });
      });
    });

    // Drag-to-scroll
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    el.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - el.offsetLeft;
      scrollLeft = el.scrollLeft;
    });
    el.addEventListener('mouseleave', () => (isDown = false));
    el.addEventListener('mouseup', () => (isDown = false));
    el.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - el.offsetLeft;
      el.scrollLeft = scrollLeft - (x - startX);
    });

    // Dot sync
    if (dots.length) {
      el.addEventListener(
        'scroll',
        () => {
          const card = el.querySelector('article');
          if (!card) return;
          const cardWidth = card.getBoundingClientRect().width + 20;
          const active = Math.round(el.scrollLeft / cardWidth);
          dots.forEach((d, i) => {
            const isActive = i === active;
            d.className = `h-1 rounded-full transition-all duration-300 ${isActive ? 'w-6 bg-navy' : 'w-3 bg-slate-300'}`;
          });
        },
        { passive: true }
      );
    }
  })();
</script>
