---
export interface Props {
  number: string;
  label: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { number, label, title, description, align = 'left' }: Props = Astro.props;
---

<div class={`flex flex-col gap-3 ${align === 'center' ? 'items-center text-center' : ''}`}>
  <div class="flex items-center gap-4" data-reveal>
    <span class="section-number">{number}</span>
    <span class="h-px w-10 bg-slate-300"></span>
    <span class="eyebrow">{label}</span>
  </div>
  <h2 class="heading-xl max-w-3xl" data-reveal style="--reveal-delay: 80ms">
    {title}
  </h2>
  {description && (
    <p class="max-w-2xl text-base sm:text-lg text-slate-600 leading-relaxed mt-2" data-reveal style="--reveal-delay: 160ms">
      {description}
    </p>
  )}
</div>
