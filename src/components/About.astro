---
import SectionHeader from '~/components/SectionHeader.astro';
import { site } from '~/data/site';
import { getDict } from '~/i18n';

const t = getDict(Astro.url).about;
const photoSrc = `${import.meta.env.BASE_URL}${site.photo}`;

// Tiny markdown processor: **bold**, _em_, [text](url)
function fmt(line: string): string {
  return line
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener" class="underline decoration-navy/30 underline-offset-4 hover:decoration-navy">$1</a>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong class="font-semibold text-navy">$1</strong>')
    .replace(/_([^_]+)_/g, '<em class="text-navy-700 not-italic">$1</em>');
}
---

<section id="sobre-mi" class="section section-divide bg-white">
  <div class="container">
    <SectionHeader
      number={t.number}
      label={t.kicker}
      title={t.title}
      description={t.description}
    />

    <div class="mt-14 grid lg:grid-cols-[auto,1fr] gap-10 lg:gap-14 items-start">
      <div class="relative mx-auto lg:mx-0" data-reveal>
        <div class="relative w-64 sm:w-72 aspect-[4/5] rounded-2xl overflow-hidden border border-slate-200 shadow-lg shadow-navy/5">
          <img
            src={photoSrc}
            alt={`${site.shortName}`}
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover"
          />
        </div>
        <div class="absolute -bottom-4 -left-4 rounded-xl border border-slate-200 bg-white px-3 py-2 shadow-md text-xs">
          <p class="font-mono text-slate-400">{t.photoBadgeNow}</p>
          <p class="mt-0.5 text-navy font-semibold">{site.shortName}</p>
        </div>
        <div class="absolute -top-3 -right-3 h-20 w-20 rounded-full bg-navy/10 blur-2xl pointer-events-none"></div>
      </div>

      <div class="space-y-8">
        <div class="space-y-5 text-lg leading-relaxed text-slate-700 max-w-2xl" data-reveal style="--reveal-delay: 120ms">
          {t.paragraphs.map((p, i) => (
            i === 0 ? (
              <p class="relative pl-5">
                <span class="absolute left-0 top-2 bottom-2 w-0.5 bg-navy/20"></span>
                <Fragment set:html={fmt(p)} />
              </p>
            ) : i === t.paragraphs.length - 1 ? (
              <p class="text-navy font-medium" set:html={fmt(p)} />
            ) : (
              <p set:html={fmt(p)} />
            )
          ))}
        </div>

        <div class="grid sm:grid-cols-3 gap-4" data-reveal style="--reveal-delay: 220ms">
          {t.cards.map((c) => (
            <div class="card">
              <p class="section-number">{c.k}</p>
              <p class="mt-2 font-display text-lg text-navy">{c.title}</p>
              <p class="mt-1.5 text-sm text-slate-500 leading-relaxed">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
