---
import { site } from '~/data/site';

export interface Props {
  variant?: 'default' | 'large';
}

const { variant = 'default' }: Props = Astro.props;

const size = variant === 'large' ? 'h-11 w-11' : 'h-9 w-9';
const icon = variant === 'large' ? 'h-5 w-5' : 'h-4 w-4';

const waHref = site.whatsapp
  ? `https://wa.me/${site.whatsapp.replace(/[^0-9]/g, '')}`
  : null;
---

<ul class="flex items-center gap-3">
  {site.email && (
    <li>
      <a
        href={`mailto:${site.email}`}
        aria-label="Enviar email"
        title="Email"
        class={`grid ${size} place-items-center rounded-full border border-white/10 bg-white/5 text-slate-300 transition hover:text-white hover:border-white/25 hover:bg-white/10`}
      >
        <svg class={icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="m3 7 9 6 9-6" />
        </svg>
      </a>
    </li>
  )}

  {site.socials.linkedin && (
    <li>
      <a
        href={site.socials.linkedin}
        target="_blank"
        rel="noopener"
        aria-label="Ver perfil de LinkedIn"
        title="LinkedIn"
        class={`grid ${size} place-items-center rounded-full border border-white/10 bg-white/5 text-slate-300 transition hover:text-white hover:border-white/25 hover:bg-white/10`}
      >
        <svg class={icon} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0Z" />
        </svg>
      </a>
    </li>
  )}

  {waHref && (
    <li>
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        aria-label="Escribir por WhatsApp"
        title="WhatsApp"
        class={`grid ${size} place-items-center rounded-full border border-white/10 bg-white/5 text-slate-300 transition hover:text-white hover:border-white/25 hover:bg-white/10`}
      >
        <svg class={icon} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.47 14.38c-.3-.15-1.75-.86-2.02-.96-.27-.1-.47-.15-.67.15-.2.3-.77.96-.95 1.16-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.38-1.47-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01s-.52.07-.8.37c-.27.3-1.04 1.02-1.04 2.49 0 1.47 1.06 2.89 1.21 3.09.15.2 2.09 3.2 5.07 4.49.71.31 1.26.49 1.69.63.71.23 1.35.2 1.86.12.57-.08 1.75-.71 2-1.4.25-.69.25-1.28.17-1.4-.07-.12-.27-.2-.57-.35ZM12.04 21.5h-.01a9.46 9.46 0 0 1-4.82-1.32l-.35-.21-3.58.94.96-3.49-.22-.36a9.44 9.44 0 0 1-1.45-5.04c0-5.22 4.25-9.46 9.47-9.46 2.53 0 4.9.99 6.68 2.77a9.38 9.38 0 0 1 2.77 6.69c0 5.22-4.25 9.46-9.45 9.46Zm8.05-17.5A11.2 11.2 0 0 0 12.04 1C5.83 1 .77 6.05.77 12.25c0 1.98.52 3.91 1.5 5.61L.67 23.5l5.78-1.52a11.2 11.2 0 0 0 5.58 1.43h.01c6.22 0 11.27-5.05 11.27-11.25a11.19 11.19 0 0 0-3.22-8Z" />
        </svg>
      </a>
    </li>
  )}

  {site.socials.github && (
    <li>
      <a
        href={site.socials.github}
        target="_blank"
        rel="noopener"
        aria-label="Ver perfil de GitHub"
        title="GitHub"
        class={`grid ${size} place-items-center rounded-full border border-white/10 bg-white/5 text-slate-300 transition hover:text-white hover:border-white/25 hover:bg-white/10`}
      >
        <svg class={icon} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5A11.5 11.5 0 0 0 .5 12c0 5.08 3.29 9.38 7.86 10.9.57.1.78-.25.78-.56 0-.27-.01-1-.02-1.96-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.35.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.17 1.18a10.98 10.98 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.77.11 3.06.74.8 1.18 1.82 1.18 3.08 0 4.41-2.69 5.39-5.25 5.67.41.36.78 1.06.78 2.13 0 1.54-.02 2.78-.02 3.16 0 .31.21.67.79.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z" />
        </svg>
      </a>
    </li>
  )}
</ul>
