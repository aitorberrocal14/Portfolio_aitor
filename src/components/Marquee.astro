---
import { marqueeItems } from '~/data/site';

const items = [...marqueeItems, ...marqueeItems];
---

<section id="marquee" class="relative overflow-hidden py-10 bg-white border-y border-slate-200">
  <div class="flex whitespace-nowrap animate-marquee gap-8">
    {items.map((item) => (
      <span class="flex items-center gap-8 font-display text-2xl sm:text-3xl text-navy/80">
        <span>{item}</span>
        <svg class="h-4 w-4 text-navy/30 flex-none" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
        </svg>
      </span>
    ))}
  </div>
</section>
