---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getDict, notesSegment } from '~/i18n';

const t = getDict(Astro.url).notesPage;
const all = await getCollection('notes', ({ id, data }) => id.startsWith('en/') && !data.draft);
const notes = all.sort((a, b) => +b.data.date - +a.data.date);
const base = import.meta.env.BASE_URL;
const root = base.endsWith('/') ? base : base + '/';
const localeRoot = `${root}en/`;
const dateLabel = (d: Date) =>
  d.toLocaleDateString('en-US', { day: '2-digit', month: 'long', year: 'numeric' });
---

<Base title={`${t.title} — Aitor Berrocal Lorda`} description={t.description}>
  <section class="section">
    <div class="container max-w-3xl">
      <p class="section-number">{t.kicker}</p>
      <h1 class="heading-xl mt-3">{t.title}</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed max-w-2xl">{t.description}</p>

      {notes.length === 0 ? (
        <p class="mt-12 text-slate-500 italic">{t.empty}</p>
      ) : (
        <ul class="mt-12 space-y-8">
          {notes.map((n) => {
            const slug = n.slug.replace(/^en\//, '');
            const href = `${localeRoot}${notesSegment.en}/${slug}/`;
            return (
              <li class="border-b border-slate-200 pb-8 last:border-b-0">
                <a href={href} class="block group">
                  <p class="section-number">{dateLabel(n.data.date)}</p>
                  <h2 class="mt-2 font-display text-2xl sm:text-3xl text-navy tracking-tight group-hover:opacity-80 transition">
                    {n.data.title}
                  </h2>
                  {n.data.description && (
                    <p class="mt-2 text-slate-600 leading-relaxed">{n.data.description}</p>
                  )}
                  {n.data.tags && n.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {n.data.tags.map((tag) => <span class="pill">{tag}</span>)}
                    </div>
                  )}
                  <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-navy group-hover:gap-2.5 transition-all">
                    {t.readMore}
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      )}

      <div class="mt-16">
        <a href={localeRoot} class="link inline-flex items-center gap-1.5 text-sm">{t.backToHome}</a>
      </div>
    </div>
  </section>
</Base>
